// archivo: schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Enum para el Rol del Cliente
enum Rol {
  Admin
  Regular
}

// 2. Modelo Cliente (Incluye Rol y Auth UID de Firebase)
model Cliente {
  cliente_id     Int       @id @unique @default(autoincrement())
  auth_uid       String?   @unique
  rol            Rol       @default(Regular)
  nombreCompleto String
  correo         String    @unique
  contrasena     String
  pushToken      String?
  metricas       Metrica[]
}

model Empresa {
  empresa_id     Int     @id @unique @default(autoincrement())
  auth_uid       String  @unique
  nombreCompleto String
  correo         String  @unique
  contrasena     String
  pushToken      String?

  // --- NUEVOS CAMPOS (Opcionales para permitir registro parcial) ---
  fotoPerfil       String? // URL de la imagen
  fotoDescripcion1 String? // URL de la imagen
  fotoDescripcion2 String? // URL de la imagen
  fotoDescripcion3 String? // URL de la imagen
  ubicacionMaps    String? // Link de Google Maps o Lat/Lng
  descuento        String? // Ej: "10%", "2x1"
  descripcion      String? // Texto largo
  pais             String?
  ciudad           String?
  categoria        String? // Ej: "Restaurante", "Tecnología"

  metricas  Metrica[]
  productos Producto[]
}

model Producto {
  producto_id Int     @id @default(autoincrement())
  nombre      String
  precio      Float
  imagenUrl   String
  descripcion String?
  empresa_id  Int

  empresa Empresa @relation(fields: [empresa_id], references: [empresa_id])
}

// 4. Modelo Metrica (Relaciones N:M entre Cliente y Empresa)
model Metrica {
  metrica_id Int  @id @default(autoincrement())
  cliente_id Int
  empresa_id Int
  vecesScan  Int
  puntos     Int?

  cliente Cliente @relation(fields: [cliente_id], references: [cliente_id])
  empresa Empresa @relation(fields: [empresa_id], references: [empresa_id])

  // Asegura que un Cliente solo tenga una fila de métricas por Empresa
  @@unique([cliente_id, empresa_id])
}
