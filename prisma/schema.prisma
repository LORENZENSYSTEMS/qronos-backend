generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Define Metrica PRIMERO
model Metrica {
  metrica_id Int @id @default(autoincrement()) 
  cliente_id Int 
  empresa_id Int 
  vecesScan  Int
  puntos     Int?

  cliente Cliente @relation(fields: [cliente_id], references: [cliente_id])
  empresa Empresa @relation(fields: [empresa_id], references: [empresa_id])

  @@unique([cliente_id, empresa_id]) 
}

// 2. Cliente
model Cliente {
  cliente_id      Int      @unique @id @default(autoincrement())
  auth_uid        String   @unique // ⬅️ ID ÚNICO DEL SISTEMA DE AUTENTICACIÓN (EJ: UID de Firebase)
  nombreCompleto  String
  correo          String   @unique
  contrasena      String 
  // ❌ Se eliminaron: contrasena, isVerified, verificationToken, tokenExpiresAt
  
  metricas        Metrica[]
}

// 3. Empresa
model Empresa {
  empresa_id      Int      @unique @id @default(autoincrement())
  auth_uid        String   @unique // ⬅️ ID ÚNICO DEL SISTEMA DE AUTENTICACIÓN (EJ: UID de Firebase)
  nombreCompleto  String
  correo          String   @unique
  contrasena      String
  // ❌ Se eliminaron: contrasena, isVerified, verificationToken, tokenExpiresAt
  
  metricas        Metrica[]
}